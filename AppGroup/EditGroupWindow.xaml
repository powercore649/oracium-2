<winex:WindowEx xmlns:winex="using:WinUIEx" Width="530" Height="650" 
    x:Class="AppGroup.EditGroupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AppGroup"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Edit Group">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <ContentDialog x:Name="EditItemDialog">
            <ContentDialog.Resources>
                <Thickness x:Key="ContentDialogPadding">0,0,0,-5</Thickness>
            </ContentDialog.Resources>
            <StackPanel Spacing="10" VerticalAlignment="Center" Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}" CornerRadius="5" HorizontalAlignment="Stretch"     Width="400">
                <Grid Padding="10,0,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="250"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="EditTitle" FontSize="20" Margin="10" HorizontalAlignment="Stretch"  VerticalAlignment="Center" FontWeight="SemiBold"></TextBlock>
                    <Button Click="CloseEditDialog" Grid.Column="1"  Background="Transparent" Height="35" HorizontalAlignment="Right"  BorderThickness="0">
                        <FontIcon Glyph="&#xe711;" FontSize="15"/>
                    </Button>
                </Grid>
                <StackPanel Spacing="0" Padding="15,0,15,15">
                    <StackPanel Spacing="3">
                        <StackPanel CornerRadius="5" Padding="10" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="5">
                                    <Button x:Name="BrowseItemIconButton" Padding="5" Click="BrowseItemIcon_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Image x:Name="ItemIconPreview" Width="50" Height="50" Stretch="UniformToFill"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="ResetItemIconButton" Click="ResetItemIcon_Click" HorizontalAlignment="Center">
                                        <TextBlock Text="Reset" FontSize="12" Opacity="0.7"/>
                                    </Button>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <StackPanel CornerRadius="5" Padding="5" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                        <TextBlock Margin="5,0,0,0" Opacity="0.8" FontSize="12">Title</TextBlock>
                                        <TextBox x:Name="TooltipTextBox" FontWeight="SemiBold" PlaceholderText="Enter Title" BorderBrush="Transparent" Background="Transparent"/>
                                    </StackPanel>
                                    <StackPanel CornerRadius="5" Padding="5" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                        <TextBlock Margin="5,0,0,0" Opacity="0.8" FontSize="12">Argument</TextBlock>
                                        <TextBox x:Name="ArgsTextBox" FontWeight="SemiBold" PlaceholderText="Enter Arguments" BorderBrush="Transparent" Background="Transparent"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                    <Grid Margin="0,10,0,0">
                        <Button HorizontalAlignment="Right" Click="EditItemSave_Click" Style="{StaticResource AccentButtonStyle}">Save</Button>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ContentDialog>

        <ContentDialog x:Name="CustomDialog">
            <ContentDialog.Resources>
                <Thickness x:Key="ContentDialogPadding">0,0,0,0</Thickness>
            </ContentDialog.Resources>
            <StackPanel Spacing="10" VerticalAlignment="Center" Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}" CornerRadius="5" HorizontalAlignment="Stretch">
                <Grid Padding="10,0,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="250"/>

                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="20" Margin="10" VerticalAlignment="Center" FontWeight="SemiBold">Grid Icon</TextBlock>
                    <Button Click="CloseDialog" Grid.Column="1" Height="35" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xe711;" FontSize="15"/>
                    </Button>
                </Grid>
                <StackPanel Spacing="0" Padding="15,0,15,15">
                    <Button BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" FontSize="12" Padding="5" Click="RegularClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Spacing="20" Padding="10" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xe91b;" FontSize="25"/>
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold">Regular Icon</TextBlock>
                                <TextBlock FontSize="13">Choose an icon from a directory</TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <Button BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" FontSize="12" Padding="5" Click="GridClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Spacing="20" Padding="10" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xf0e2;" FontSize="25"/>
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold">Grid Icon</TextBlock>
                                <TextBlock FontSize="13">Create grid icon from selected applications</TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ContentDialog>

        <ContentDialog x:Name="CustomizeDialog" >
            <ContentDialog.Resources>
                <Thickness x:Key="ContentDialogPadding">0,0,0,0</Thickness>
               
            </ContentDialog.Resources>
            
            <StackPanel Spacing="10" VerticalAlignment="Center" Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}" CornerRadius="5" HorizontalAlignment="Stretch">
                <Grid Padding="10,0,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="250"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="20" Margin="10" VerticalAlignment="Center" FontWeight="SemiBold">Customize</TextBlock>
                    <Button Click="CloseCustomizeDialog" Grid.Column="1" Height="35" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xe711;" FontSize="15"/>
                    </Button>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                    <StackPanel Spacing="0" Padding="15,0,15,15">

                        <StackPanel Orientation="Vertical" Grid.Column="1" Margin="0,0,0,2" VerticalAlignment="Center" Padding="10,15,15,15" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="5">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Columns"/>
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Number of columns in the grid." FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                                <ComboBox x:Name="GroupColComboBox" Grid.Column="1" SelectionChanged="GroupColComboBox_SelectionChanged"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,2" VerticalAlignment="Center" 
Padding="10,10,15,10" 
Background="{ThemeResource CardBackgroundFillColorDefault}" 
BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
CornerRadius="5">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Layout"/>
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Content area background style" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                                <ComboBox x:Name="LayoutComboBox" Grid.Column="1" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Default" IsSelected="True"/>
                                    <ComboBoxItem Content="Card"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>


                        <!-- Header Expander -->
                        <Expander HorizontalAlignment="Stretch"
                              IsExpanded="False"
                              ExpandDirection="Down"
                              Background="Transparent"
                              VerticalAlignment="Top"
                              Padding="0"
                              Margin="0,0,0,2"
                              HorizontalContentAlignment="Stretch"
                              CornerRadius="5"
                              BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <Expander.Header>
                                <StackPanel x:Name="HeaderPanel" Orientation="Vertical" Margin="-10,0,-15,0" VerticalAlignment="Center" Padding="15,10,0,10">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock VerticalAlignment="Center" Text="Header"/>
                                            <TextBlock VerticalAlignment="Center" Text="Show group name header" FontSize="12" Opacity="0.7"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1" x:Name="GroupHeader" OnContent="" OffContent="" Toggled="GroupHeader_Toggled"/>
                                    </Grid>
                                </StackPanel>
                            </Expander.Header>
                            <Expander.Content>
                                <StackPanel>
                                    <StackPanel x:Name="HeaderPositionPanel" Orientation="Vertical" HorizontalAlignment="Stretch"
                            Padding="40,10,50,10" 
                            Background="{ThemeResource CardBackgroundFillColorSecondary}" 
                            BorderThickness="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            CornerRadius="0,0,5,5">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center">Position</TextBlock>
                                            <ComboBox x:Name="HeaderPositionComboBox" Grid.Column="1" VerticalAlignment="Center" IsEnabled="False">
                                                <ComboBoxItem Content="Top"/>
                                                <ComboBoxItem Content="Bottom" IsSelected="True"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Expander.Content>
                        </Expander>

                        <!-- Layout -->


                        <Expander
           x:Name="ExpanderLabel"
           Grid.Row="1"
           HorizontalAlignment="Stretch"
           IsExpanded="False"
           ExpandDirection="Down"
           Background="Transparent"
           VerticalAlignment="Top"
           Padding="0"
             HorizontalContentAlignment="Stretch"
           CornerRadius="5"
           BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        >
                            <Expander.Header>

                                <StackPanel Orientation="Vertical"  Margin="-10,0,-15,0" VerticalAlignment="Center" Padding="15,10,0,10">
                                    <Grid HorizontalAlignment="Stretch" >
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock  VerticalAlignment="Center" Text="Labels"/>
                                            <TextBlock  VerticalAlignment="Center" Text="Show or Hide program labels" FontSize="12" Opacity="0.7"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1" x:Name="ShowLabels" OnContent="" OffContent="" Toggled="ShowLabels_Toggled"/>

                                    </Grid>
                                </StackPanel>
                            </Expander.Header>
                            <Expander.Content >
                                <StackPanel>
                                    <StackPanel  x:Name="LabelSizePanel"   Orientation="Vertical" Grid.Column="1" HorizontalAlignment="Stretch"    Padding="40,10,50,10" Background="{ThemeResource CardBackgroundFillColorSecondary}" BorderThickness="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"  CornerRadius="0" >
                                        <Grid HorizontalAlignment="Stretch"
                       >
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center">Text Size</TextBlock>
                                            <ComboBox x:Name="LabelSizeComboBox" Grid.Column="1" IsEnabled="False"/>
                                        </Grid>

                                    </StackPanel>
                                    <StackPanel  x:Name="LabelPositionPanel"   Orientation="Vertical" Grid.Column="1" HorizontalAlignment="Stretch" Padding="40,10,50,10" Background="{ThemeResource CardBackgroundFillColorSecondary}" BorderThickness="0,1,0,0"  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="0,0,5,5" >
                                        <Grid HorizontalAlignment="Stretch"
>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center">Position</TextBlock>
                                            <ComboBox  Grid.Column="1" IsEnabled="False" x:Name="LabelPositionComboBox"/>
                                        </Grid>

                                    </StackPanel>
                                </StackPanel>
                            </Expander.Content>

                        </Expander>
                        <TextBlock VerticalAlignment="Center" Text="Others" FontWeight="SemiBold" Margin="5,30,5,5"/>

                        <!-- Show on Tray -->
                        <StackPanel Orientation="Vertical" Margin="0,0,0,2" VerticalAlignment="Center"
    Padding="10,10,15,10"
    Background="{ThemeResource CardBackgroundFillColorDefault}"
    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
    CornerRadius="5">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Show on Tray"/>
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Show group icon in system tray" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="ShowOnTray" OnContent="" OffContent=""/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </ContentDialog>
        <Grid Padding="20,50,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <Grid ColumnSpacing="10" Margin="10,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBox FontWeight="SemiBold" x:Name="GroupNameTextBox" PlaceholderText="App Group..." FontSize="25" Height="45" TextChanged="GroupNameTextBox_TextChanged" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" TextWrapping="Wrap">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Grid.Column="1" Padding="10,0,0,0" FontSize="12" Opacity=".8" VerticalAlignment="Center">Group Name</TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Padding="5" VerticalAlignment="Center" CornerRadius="5" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefault}" Orientation="Horizontal">
                        <ComboBox x:Name="IconGridComboBox" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Visibility="Collapsed" SelectionChanged="IconGridComboBox_SelectionChanged" Margin="0,0,0,0" Grid.Column="0"/>
                        <Button x:Name="BrowseIconButton" Background="Transparent" BorderThickness="0" FontSize="12" Padding="5" Click="BrowseIconButton_Click">
                            <Border x:Name="IconPreviewBorder" CornerRadius="3">
                                <StackPanel Orientation="Horizontal">
                                    <Image x:Name="IconPreviewImage" Stretch="UniformToFill" Width="50" Height="50" Source="ms-appx:///default_preview.png"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>
                </Grid>
                <InfoBar Margin="10,0,10,0" IsOpen="False" Severity="Warning" x:Name="RenameInfoBar" Message="Renaming a group requires 'Force Taskbar Update' or re-pinning to the taskbar."/>
            </StackPanel>

            <Grid Grid.Row="1" Padding="10,10,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="0"  CornerRadius="5" Padding="0,0,0,0" Orientation="Vertical" VerticalAlignment="Center">

                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Grid ColumnSpacing="2" Margin="0,0,0,2" CornerRadius="5" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                       
                    </Grid>
                    <!--<Grid ColumnSpacing="2" Margin="0,0,0,0" CornerRadius="5" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Padding="6" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="5">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Show Labels"/>
                                <ToggleSwitch Grid.Column="1" x:Name="ShowLabels" OnContent="" OffContent="" Toggled="ShowLabels_Toggled"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="LabelSizePanel"  Orientation="Vertical" Grid.Column="1" VerticalAlignment="Center" Padding="10" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="5" Opacity="0.5">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center">Label Size</TextBlock>
                                <ComboBox x:Name="LabelSizeComboBox" Grid.Column="1" IsEnabled="False"/>
                            </Grid>
                        </StackPanel>
                    </Grid>-->
                </StackPanel>


                 <Grid Grid.Row="2" Margin="0,5,0,0" HorizontalAlignment="Stretch" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="1" CornerRadius="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" HorizontalAlignment="Stretch" Margin="15,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ApplicationCount" FontWeight="SemiBold" VerticalAlignment="Center"></TextBlock>
                        </StackPanel>
                        <Button  Padding="10" Margin="0,5,0,5" Background="Transparent" BorderThickness="0" Grid.Column="1" Click="CustomizeDialog_Click">
                            <FontIcon Glyph="&#xe9e9;" FontSize="15"/>
                        </Button>

                        <Button Click="BrowseFilesClick" Padding="10" Margin="0,5,0,5" 
        Background="Transparent" BorderThickness="0" Grid.Column="2">
                           
                            <FontIcon Glyph="&#xe710;" FontSize="15"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="2" Margin="10,0,10,10" Background="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="1" CornerRadius="5">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListView x:Name="ExeListView" ScrollViewer.IsDeferredScrollingEnabled="True"  Background="Transparent" CanReorderItems="True" CanDragItems="True" DragEnter="ExeListView_DragEnter" Drop="ExeListView_Drop"   DragOver="ExeListView_DragOver" DragItemsCompleted="ExeListView_DragItemsCompleted" AllowDrop="True" SelectionChanged="ExeListView_SelectionChanged" Margin="0,5,0,5" SelectionMode="Single">
                                <ListView.Resources>
                                    <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">False</x:Boolean>
                                </ListView.Resources>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch" ColumnSpacing="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="15" Padding="0,10,0,10" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}" Width="25" Height="25"/>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button Click="EditItem_Click" Padding="10" Background="Transparent" BorderThickness="0" Tag="{Binding}" Grid.Column="1" HorizontalAlignment="Right">
                                                <FontIcon Glyph="&#xe70f;" FontSize="12"/>
                                            </Button>
                                            <Button Click="RemoveItem_Click" Padding="10" Background="Transparent" BorderThickness="0" Tag="{Binding}" Grid.Column="2" HorizontalAlignment="Right">
                                                <FontIcon Glyph="&#xe711;" FontSize="12"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <Button Grid.Row="3" x:Name="CreateShortcutButton" Content="Save" Margin="0,10,0,20"  HorizontalAlignment="Right" Click="CreateShortcut_Click" Style="{StaticResource AccentButtonStyle}">
                    
                </Button>
            </Grid>
        </Grid>
    </Grid>
</winex:WindowEx>